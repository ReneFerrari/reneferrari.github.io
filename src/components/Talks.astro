---
const talks = [
  {
    event: 'Droidcon Berlin 2025',
    title: 'Reworking a Core Feature: Migrating from XML to Compose Maps',
    description:
      "Full refactor of Tractive's map screen — architectural rework and migration from XML Google Maps to Compose Google Maps.",
    youtubeUrl: '#',
  },
  {
    event: 'GDG Linz 2025',
    title: 'Design to Code',
    description:
      'Transforming Figma designs to Compose code using AI — pre-processing Figma JSON and GitHub Copilot Agent Mode with a custom prompt.',
    youtubeUrl: '#',
  },
];
---

<section class="py-28 px-4 talks-section">
  <div class="max-w-6xl mx-auto">

    <div class="fade-in mb-14">
      <span class="font-mono text-accent text-xs tracking-[0.2em] uppercase">Speaking</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-[#f1f5f9] mt-2">Talks</h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {talks.map(({ event, title, description, youtubeUrl }) => (
        <div class="fade-in card rounded-2xl p-8 flex flex-col">
          <!-- Event badge -->
          <span class="inline-flex items-center gap-1.5 font-mono text-xs text-accent uppercase tracking-widest mb-5">
            <span class="w-1.5 h-1.5 rounded-full bg-accent inline-block shrink-0"></span>
            {event}
          </span>

          <h3 class="text-lg font-semibold text-[#f1f5f9] mb-3 leading-snug flex-1">
            {title}
          </h3>

          <p class="text-[#94a3b8] text-sm leading-relaxed mb-7">
            {description}
          </p>

          <a
            href={youtubeUrl}
            class="inline-flex items-center gap-2 text-sm text-accent font-mono hover:text-accent/70 transition-colors group"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="shrink-0"
            >
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
            </svg>
            Watch on YouTube
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              class="group-hover:translate-x-0.5 transition-transform"
            >
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .talks-section {
    background: rgba(17, 24, 39, 0.45);
  }
</style>
