---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden px-4">
  <!-- Animated background blobs -->
  <div class="blobs" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto text-center">
    <!-- Eyebrow -->
    <p class="font-mono text-accent text-xs sm:text-sm tracking-[0.2em] uppercase mb-6 opacity-80">
      Linz, Austria · Android Engineer
    </p>

    <!-- Name -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold text-[#f1f5f9] mb-6 leading-none tracking-tight">
      Rene Ferrari
    </h1>

    <!-- Typewriter -->
    <div class="flex items-center justify-center gap-1 text-xl sm:text-2xl text-accent font-mono mb-8 h-10">
      <span id="typewriter" aria-live="polite"></span>
      <span class="cursor" aria-hidden="true">|</span>
    </div>

    <!-- One-liner -->
    <p class="text-[#94a3b8] text-lg sm:text-xl max-w-2xl mx-auto mb-12 leading-relaxed">
      Building scalable Android apps used by millions. Passionate about clean
      architecture, modern tooling, and sharing knowledge.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="mailto:rene_ferrari@outlook.de"
        class="inline-flex items-center gap-2.5 px-7 py-3.5 rounded-lg border border-accent/30 text-[#f1f5f9] text-sm font-medium hover:border-accent/60 hover:text-accent active:scale-95 transition-all"
      >
        Get in Touch
      </a>
      <a
        href="https://www.linkedin.com/in/rene-ferrari/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 px-7 py-3.5 rounded-lg border border-accent/30 text-[#f1f5f9] text-sm font-medium hover:border-accent/60 hover:text-accent active:scale-95 transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
    </div>
  </div>
</section>

<style>
  .blobs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    background: #3ddc84;
    filter: blur(90px);
    opacity: 0.07;
  }

  .blob-1 {
    width: 55%;
    height: 65%;
    top: 10%;
    left: -15%;
    animation: drift1 18s ease-in-out infinite alternate;
  }

  .blob-2 {
    width: 45%;
    height: 55%;
    top: -20%;
    right: -5%;
    animation: drift2 22s ease-in-out infinite alternate;
  }

  .blob-3 {
    width: 35%;
    height: 40%;
    bottom: 0%;
    right: 20%;
    opacity: 0.04;
    animation: drift3 16s ease-in-out infinite alternate;
  }

  @keyframes drift1 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(18%, 12%) scale(1.1); }
  }

  @keyframes drift2 {
    from { transform: translate(0, 0) scale(1.05); }
    to   { transform: translate(-12%, 18%) scale(0.95); }
  }

  @keyframes drift3 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-20%, -15%) scale(1.15); }
  }

  .cursor {
    display: inline-block;
    color: #3ddc84;
    animation: blink 1.1s step-end infinite;
    line-height: 1;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<script>
  const roles = [
    'Senior Android Developer',
    'Architecture Co-Lead',
    'University Teacher',
    'Conference Speaker',
  ];

  let roleIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  let timeoutId: ReturnType<typeof setTimeout>;

  const el = document.getElementById('typewriter');

  function type() {
    if (!el) return;
    const current = roles[roleIndex];

    if (isDeleting) {
      el.textContent = current.substring(0, charIndex - 1);
      charIndex--;
    } else {
      el.textContent = current.substring(0, charIndex + 1);
      charIndex++;
    }

    if (!isDeleting && charIndex === current.length) {
      timeoutId = setTimeout(() => {
        isDeleting = true;
        type();
      }, 2200);
      return;
    }

    if (isDeleting && charIndex === 0) {
      isDeleting = false;
      roleIndex = (roleIndex + 1) % roles.length;
    }

    const speed = isDeleting ? 38 : 85;
    timeoutId = setTimeout(type, speed);
  }

  type();
</script>
