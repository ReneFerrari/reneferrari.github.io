---
const stats = [
  { value: '8+',   label: 'Years Experience' },
  { value: '4M+',  label: 'App Downloads'    },
  { value: '2',    label: 'Conf. Talks'       },
  { value: '0→30%', label: 'Test Coverage Lift' },
];
---

<section id="about" class="py-28 px-4">
  <div class="max-w-6xl mx-auto">

    <div class="fade-in mb-14">
      <span class="font-mono text-accent text-xs tracking-[0.2em] uppercase">About</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-[#f1f5f9] mt-2">Who I am</h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-14 items-start">

      <!-- Text -->
      <div class="fade-in space-y-5">
        <div class="photo-wrap mb-6">
          <img src="/pic.png" alt="Rene Ferrari" class="photo-img" />
        </div>
        <p class="text-[#94a3b8] text-lg leading-relaxed">
          I'm an Android Engineer with <span class="text-[#f1f5f9] font-semibold">8+ years of experience</span>,
          currently at <span class="text-accent font-semibold">Tractive</span> — a GPS &amp; wellness tracking
          app with <span class="font-mono text-accent">several million</span> downloads. I co-lead architecture decisions,
          drive technical innovation, and mentor teammates across the engineering org.
        </p>
        <p class="text-[#94a3b8] text-lg leading-relaxed">
          I've spoken at <span class="text-[#f1f5f9] font-semibold">Droidcon Berlin</span> and
          <span class="text-[#f1f5f9] font-semibold">GDG Linz</span>, and teach Android development at
          <span class="text-[#f1f5f9] font-semibold">FH Hagenberg</span> as an adjunct lecturer.
        </p>
        <p class="text-[#94a3b8] text-lg leading-relaxed">
          My focus sits at the intersection of clean architecture, developer experience, mentoring, and AI tooling
        </p>
      </div>

      <!-- Stats grid -->
      <div class="fade-in grid grid-cols-2 gap-4">
        {stats.map(({ value, label }) => (
          <div class="card rounded-2xl p-6 text-center">
            <div class="text-3xl font-bold text-accent font-mono mb-1.5">{value}</div>
            <div class="text-xs text-[#94a3b8] uppercase tracking-widest">{label}</div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .photo-wrap {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid rgba(61, 220, 132, 0.25);
    box-shadow: 0 0 32px rgba(61, 220, 132, 0.1), 0 4px 16px rgba(0, 0, 0, 0.4);
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
</style>
